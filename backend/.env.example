# backend/.env.example

# Party ID of the operator/admin (your validator's party hint)
APP_PROVIDER_PARTY=your-org-function-1::abc123...

# Canton Ledger API (set up via nginx in canton-validator-setup/scripts/proxy.sh)
LEDGER_URL=https://ledger.yourdomain.com

# Canton Ledger API gRPC endpoint — used for admin topology ops (package vetting)
# host:port form; set LEDGER_GRPC_TLS=false for plaintext (local/dev only)
LEDGER_GRPC_URL=grpc.yourdomain.com:443
LEDGER_GRPC_TLS=true

# Target synchronizer for vetting topology transactions
SYNCHRONIZER_ID=global-domain::1220...

# Splice validator app — used for wallet onboarding (POST /api/validator/v0/register)
VALIDATOR_URL=https://wallet.yourdomain.com

# Keycloak client credentials for the backend service account
# See: canton-validator-setup/scripts/auth.sh → validator-app client
LEDGER_TOKEN_URL=https://auth.yourdomain.com/realms/canton/protocol/openid-connect/token
LEDGER_CLIENT_ID=validator-app
LEDGER_CLIENT_SECRET=<from keycloak>

# PQS postgres connection string
# See: canton-validator-setup/scripts/pqs.sh
PQS_URL=postgresql://pqs:pqs@localhost:5432/pqs

# Keycloak JWKS endpoint for validating user JWTs
JWKS_URI=https://auth.yourdomain.com/realms/canton/protocol/openid-connect/certs

# JWT audience claim (default is correct for Canton Network)
JWKS_AUDIENCE=https://canton.network.global

# OpenTelemetry (optional)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
# OTEL_SERVICE_NAME=canton-devnet-backend

# Keycloak Admin REST API — used for user registration
# Create a service account client in your Keycloak admin console with
# the "realm-management > manage-users" role granted.
KEYCLOAK_BASE_URL=https://auth.yourdomain.com
KEYCLOAK_REALM=canton
KEYCLOAK_ADMIN_CLIENT_ID=backend-admin
KEYCLOAK_ADMIN_CLIENT_SECRET=<from keycloak>
